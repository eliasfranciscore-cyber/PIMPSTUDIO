{
  "version": 2,
  "routes": [
    { "src": "^/api/(.*)$", "dest": "/api/$1" },
    { "src": "^/$", "dest": "/web/index.html" },
    { "src": "^/login$", "dest": "/web/login.html" },
    { "src": "^/booking$", "dest": "/web/booking.html" },
    { "src": "^/dashboard$", "dest": "/web/dashboard.html" },
    { "src": "^/assets/(.*)$", "dest": "/web/assets/$1" },
    { "src": "^/styles.css$", "dest": "/web/styles.css" },
    { "src": "^/app.js$", "dest": "/web/app.js" },
    { "handle": "filesystem" },
    { "src": "^(.*)$", "dest": "/web/index.html" }
  ]
}
