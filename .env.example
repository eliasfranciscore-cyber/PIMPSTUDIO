# NEON PostgreSQL — copia este archivo a .env y completa los valores
DATABASE_URL=postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Vercel Blob (legacy, ya no requerido en v2)
# BLOB_READ_WRITE_TOKEN=

# Notificaciones Web Push (iOS PWA). Genera el par de claves con:
#   npx web-push generate-vapid-keys
# La pública también debe exponerse al front como VITE_VAPID_PUBLIC_KEY.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contacto@pimpstudio.cl
VITE_VAPID_PUBLIC_KEY=
