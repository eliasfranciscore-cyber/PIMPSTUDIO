{"nodes": [{"id": "index_html", "label": "index.html (entry, meta/PWA/no-flash theme)", "file_type": "code", "source_file": "index.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "index_html_theme_script", "label": "No-flash theme init script (Santiago timezone based)", "file_type": "rationale", "source_file": "index.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Sets data-theme before first paint to avoid a flash of wrong theme: respects manual localStorage choice (ps_theme_manual/ps_theme); otherwise derives light/dark from the current hour in America/Santiago timezone (light 07:00-19:00, dark otherwise). theme-color meta and root background are set synchronously to prevent iOS status bar color mismatch."}, {"id": "concept_ps_theme_manual_storage", "label": "ps_theme_manual / ps_theme localStorage keys", "file_type": "concept", "source_file": "index.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_apple_touch_icon", "label": "apple-touch-icon PNG 180 rationale", "file_type": "rationale", "source_file": "index.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "iOS does not use SVG for the home-screen icon, so a PNG 180 is required specifically for 'Add to Home Screen', separate from the SVG/PNG192 favicon."}, {"id": "concept_theme_color_meta_sync", "label": "theme-color meta dynamic sync rationale", "file_type": "rationale", "source_file": "index.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "theme-color is synced by JS to data-theme rather than to prefers-color-scheme, because the actual displayed theme is decided by the manual toggle or Santiago local time, not the OS color scheme preference \u2014 otherwise iOS could paint status/nav bars with the wrong color relative to what's on screen."}, {"id": "concept_format_detection_meta", "label": "format-detection=telephone=no meta rationale", "file_type": "rationale", "source_file": "index.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Prevents iOS from auto-detecting phone numbers and styling them (which produces a black box artifact in light mode)."}, {"id": "index_html_lcp_preload", "label": "Hero image LCP preload (bruno-hero.jpg)", "file_type": "rationale", "source_file": "index.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Preloads the hero image with fetchpriority=high because it is the landing page's Largest Contentful Paint element, speeding up first paint."}, {"id": "concept_blackletter_fonts", "label": "Blackletter fonts (Pirata One, Manufacturing Consent)", "file_type": "concept", "source_file": "index.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "manifest_webmanifest", "label": "manifest.webmanifest (PWA manifest)", "file_type": "code", "source_file": "index.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "index_html", "target": "index_html_theme_script", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "index.html", "source_location": null, "weight": 1.0}, {"source": "index_html_theme_script", "target": "concept_ps_theme_manual_storage", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "index.html", "source_location": null, "weight": 1.0}, {"source": "index_html_theme_script", "target": "concept_theme_color_meta_sync", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "index.html", "source_location": null, "weight": 1.0}, {"source": "index_html", "target": "concept_apple_touch_icon", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "index.html", "source_location": null, "weight": 1.0}, {"source": "index_html", "target": "concept_format_detection_meta", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "index.html", "source_location": null, "weight": 1.0}, {"source": "index_html", "target": "index_html_lcp_preload", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "index.html", "source_location": null, "weight": 1.0}, {"source": "index_html", "target": "concept_blackletter_fonts", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "index.html", "source_location": null, "weight": 1.0}, {"source": "index_html", "target": "manifest_webmanifest", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "index.html", "source_location": null, "weight": 1.0}, {"source": "index_html", "target": "src_main_jsx", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "index.html", "source_location": null, "weight": 1.0}, {"source": "index_html_theme_script", "target": "concept_pwa_standalone_mode", "relation": "semantically_similar_to", "confidence": "INFERRED", "confidence_score": 0.65, "source_file": "index.html", "source_location": null, "weight": 1.0}], "hyperedges": []}