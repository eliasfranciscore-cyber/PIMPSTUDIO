 "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_database_url", "label": "DATABASE_URL env var", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_ps_session_secret", "label": "PS_SESSION_SECRET env var", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Requires >=16 chars for HMAC signing; if missing in production the system fails closed and rejects all sessions, to avoid ever accepting an unsigned/forgeable token."}, {"id": "concept_fintoc_secret_key", "label": "FINTOC_SECRET_KEY env var", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_vapid_keys", "label": "VAPID_PUBLIC_KEY / VAPID_PRIVATE_KEY / VAPID_SUBJECT env vars", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_vite_vapid_public_key", "label": "VITE_VAPID_PUBLIC_KEY env var", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_blob_read_write_token", "label": "BLOB_READ_WRITE_TOKEN env var", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_barber_passwords", "label": "BARBER_PASSWORDS env var", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "JSON fallback {code: sha256_hex} used as a login backup path when the database is unreachable, keeping barber login functional during DB outages."}, {"id": "concept_session_management", "label": "Session Management (stateless HMAC tokens)", "file_type": "rationale", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Sessions are cryptographically signed, stateless tokens with no DB lookup required, chosen so validation is fast and doesn't depend on a session table; trade-off is fail-closed behavior if the signing secret is weak/missing."}, {"id": "concept_graceful_degradation", "label": "Graceful Degradation (demo data fallback)", "file_type": "rationale", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "All endpoints return demo data on database errors instead of throwing, so the app remains usable offline and during backend/database outages."}, {"id": "concept_pwa_standalone_mode", "label": "PWA & Standalone Mode redirect", "file_type": "rationale", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "iOS 'Add to Home Screen' ignores the manifest start_url and instead relaunches the last-viewed page; isStandaloneLaunch() detects this and redirects to /panel or /ingreso once per app session to fix the entry point."}, {"id": "app_jsx_isstandalonelaunch", "label": "isStandaloneLaunch() function", "file_type": "code", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_fintoc_integration", "label": "Fintoc Integration (checkout flow)", "file_type": "rationale", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Unified checkout + webhook handler design: frontend posts to /api/fintoc-payments, gets a hosted checkout sessionUrl, then Fintoc posts back to the same endpoint with ?webhook=1 to update enrollment records after signature validation."}, {"id": "concept_vite_fintoc_mock", "label": "Vite Fintoc mock middleware (dev mode)", "file_type": "rationale", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Custom Vite middleware intercepts /api/fintoc-payments POST requests in dev mode since serverless functions aren't available under plain `npm run dev`."}, {"id": "readme_deployment_checklist", "label": "Deployment Checklist", "file_type": "document", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "src_main_jsx", "target": "src_app_jsx", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "CLAUDE.md", "source_location": null, "weight": 1.0}, {"source": "src_app_jsx", "target": "src_pages_home", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "CLAUDE.md", "source_location": null, "weight": 1.0}, {"source": "src_app_jsx", "target": "src_pages_booking", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "CLAUDE.md", "source_location": null, "weight": 1.0}, {"source": "src_app_jsx", "target": "src_pages_login", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "CLAUDE.md", "source_location": null, "weight": 1.0}, {"source": "src_app_jsx", "target": "src_pages_barberlogin", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "CLAUDE.md", "source_location": null, "weight": 1.0}, {"source": "src_app_jsx", "target": "src_pages_dashboard", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "CLAUDE.md", "source