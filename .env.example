# Copia este archivo a .env.local y completa los valores.
# NUNCA subas .env.local al repositorio (está en .gitignore).

# --- Base de datos: Neon PostgreSQL (requerida en producción) ---
DATABASE_URL=postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# --- Seguridad: secreto de firma de sesiones internas (REQUERIDO en producción) ---
# Mínimo 16 caracteres. Sin esto, el login del panel interno se rechaza (falla cerrado).
# Generar uno fuerte:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
PS_SESSION_SECRET=

# --- Respaldo de login de barberos si la DB no está disponible (opcional) ---
# JSON: { "code-del-barbero": "<sha256(contraseña)>", ... }
# BARBER_PASSWORDS={"bruno-herrera":"<sha256hex>"}

# --- Notificaciones Web Push / PWA iOS (opcional) ---
# Genera el par de claves con:  npx web-push generate-vapid-keys
# La pública también se expone al front como VITE_VAPID_PUBLIC_KEY.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contacto@brunetticutz.cl
VITE_VAPID_PUBLIC_KEY=

# --- Vercel Blob (opcional, respaldo de registro de clientes) ---
# BLOB_READ_WRITE_TOKEN=

# --- Resend: correo de confirmación de reserva al cliente (opcional) ---
# Sin RESEND_API_KEY, el envío se omite sin romper la reserva.
# El dominio del remitente debe estar verificado en Resend (o usa
# "onboarding@resend.dev" para pruebas antes de verificar el propio).
RESEND_API_KEY=
RESEND_FROM=Brunetticutz <reservas@brunetticutz.cl>
