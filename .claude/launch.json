{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dev",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "source ~/.nvm/nvm.sh && npm run dev"],
      "autoPort": true
    },
    {
      "name": "edit",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "source ~/.nvm/nvm.sh && npm run edit"],
      "autoPort": true
    },
    {
      "name": "vercel-dev",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "source ~/.nvm/nvm.sh && npx vercel dev --yes --listen 3000"],
      "port": 3000
    }
  ]
}
